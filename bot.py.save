]

MSK = pytz.timezone("Europe/Moscow")
checklist_log = {}  # {chat_id: {"morning": True/False, "evening": True/False}}

bot = Bot(token=BOT_TOKEN)
dp = Dispatcher()

def get_unit(chat_id):
    for u in UNITS:
        if u["id"] == chat_id:
            return u
    return None

@dp.message()
async def handle_message(message: Message):
    text = message.text or ""
    chat_id = message.chat.id
    unit = get_unit(chat_id)
    if not unit:
        return

    lower = text.lower()
    if "чек-лист утро" in lower:
        if chat_id not in checklist_log:
            checklist_log[chat_id] = {}
        checklist_log[chat_id]["morning"] = True
        checklist_log[chat_id]["morning_text"] = text
    elif "чек-лист вечер" in lower:
        if chat_id not in checklist_log:
            checklist_log[chat_id] = {}
        checklist_log[chat_id]["evening"] = True
        checklist_log[chat_id]["evening_text"] = text

async def send_summary(period: str):
    if not YOUR_ID:
        return
    now = datetime.now(MSK).strftime("%d.%m.%Y")
    submitted = []
    missing = []

    for unit in UNITS:
        cid = unit["id"]
        log = checklist_log.get(cid, {})
        has = log.get(period, False)
        name = unit["name"]
        if has:
            submitted.append(f"✅ {name}")
        else:
            missing.append(f"❌ {name}")

    period_label = "утро" if period == "morning" else "вечер"
    text = f"📊 Сводка {now} ({period_label})\n\n"
    text += f"Сдали: {len(submitted)}/{len(UNITS)}\n"
    if missing:
        text += "\nНе сдали:\n" + "\n".join(missing)
    if submitted:
        text += "\n\nСдали:\n" + "\n".join(submitted)

    await bot.send_message(YOUR_ID, text)

async def scheduler():
    while True:
        now = datetime.now(MSK)
        if now.hour == 10 and now.minute == 31:
            await send_summary("morning")
            await asyncio.sleep(60)
        elif now.hour == 19 and now.minute == 1:
            await send_summary("evening")
            await asyncio.sleep(60)
            checklist_log.clear()
        await asyncio.sleep(30)

async def main():
    logging.basicConfig(level=logging.INFO)
    asyncio.create_task(scheduler())
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
